# Azure Configuration
AZURE_SUBSCRIPTION_ID=your-subscription-id-here
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here

# Terraform Backend Configuration
TF_BACKEND_STORAGE_ACCOUNT=tfstatestorage
TF_BACKEND_CONTAINER_NAME=tfstate
TF_BACKEND_KEY=terraform.tfstate

# Azure Resources
AZURE_LOCATION=eastus
PROJECT_NAME=azure-k8s
ENVIRONMENT=dev

# Database Configuration
DB_ADMIN_USERNAME=dbadmin
DB_ADMIN_PASSWORD=changeme-use-strong-password
DB_NAME=appdb

# Container Registry
ACR_NAME=myacrregistry
ACR_SKU=Premium

# Kubernetes Configuration
K8S_NODE_COUNT=3
K8S_NODE_SIZE=Standard_D2s_v3
K8S_VERSION=1.27.3

# Application Configuration
BACKEND_IMAGE_TAG=latest
FRONTEND_IMAGE_TAG=latest

# ELK Stack Configuration
ELASTICSEARCH_HEAP_SIZE=2g
ELASTICSEARCH_CLUSTER_NAME=elk-cluster

# Monitoring
ENABLE_MONITORING=true
RETENTION_DAYS=30

# GitHub Configuration (for CI/CD)
GITHUB_REPO=your-org/azure-k8s-infrastructure
GITHUB_TOKEN=your-github-token-here

# Notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
ALERT_EMAIL=alerts@example.com
